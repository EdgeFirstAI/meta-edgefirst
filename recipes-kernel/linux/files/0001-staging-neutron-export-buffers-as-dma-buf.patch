From: Sébastien Taylor <sebastien@au-zone.com>
Date: Mon, 24 Mar 2026 00:00:00 -0600
Subject: [PATCH] staging: neutron: export buffers as dma-buf

Replace anon_inode_getfd() with dma_buf_export() + dma_buf_fd() in
neutron_buffer_create(), making Neutron buffer file descriptors proper
DMA-BUF fds.  This enables zero-copy buffer sharing with V4L2,
GStreamer, the Mali GPU, and other DMA-BUF-aware subsystems.

Implement struct dma_buf_ops with map/unmap/mmap/release/
begin_cpu_access/end_cpu_access callbacks.  The map_dma_buf callback
uses dma_get_sgtable_attrs() + dma_map_sgtable(attach->dev) to create
proper IOMMU mappings for the importing device, enabling external
hardware (GPU, G2D) to write into the buffer.

Update neutron_buffer_get_from_fd() to use dma_buf_get() with ops
ownership validation instead of file->private_data.

The existing mmap, cache sync, and inference paths continue to work
unchanged --- libNeutronDriver.so requires no modifications.

Upstream-Status: Inappropriate [embedded platform specific]
Signed-off-by: Sébastien Taylor <sebastien@au-zone.com>
---
 drivers/staging/neutron/neutron_buffer.c | 145 ++++++++++++++++-------
 drivers/staging/neutron/neutron_buffer.h |   3 +
 2 files changed, 106 insertions(+), 42 deletions(-)

--- a/drivers/staging/neutron/neutron_buffer.c
+++ b/drivers/staging/neutron/neutron_buffer.c
@@ -5,11 +5,12 @@
 
 /****************************************************************************/
 
-#include <linux/anon_inodes.h>
+#include <linux/dma-buf.h>
 #include <linux/dma-mapping.h>
 #include <linux/of_address.h>
 #include <linux/file.h>
 #include <linux/fs.h>
+#include <linux/scatterlist.h>
 #include <linux/uaccess.h>
 #include <linux/firmware.h>
 
@@ -19,19 +20,6 @@
 
 /****************************************************************************/
 
-static int neutron_buffer_release(struct inode *inode,
-				  struct file *file);
-
-static int neutron_buffer_mmap(struct file *file,
-			       struct vm_area_struct *vma);
-
-static const struct file_operations neutron_buffer_fops = {
-	.release        = &neutron_buffer_release,
-	.mmap           = &neutron_buffer_mmap,
-};
-
-/****************************************************************************/
-
 static void neutron_buffer_destroy(struct kref *kref)
 {
 	struct neutron_buffer *buf =
@@ -47,38 +35,112 @@
 	devm_kfree(buf->ndev->dev, buf);
 }
 
-static int neutron_buffer_release(struct inode *inode,
-				  struct file *file)
+/****************************************************************************/
+/* DMA-BUF operations                                                       */
+/****************************************************************************/
+
+static struct sg_table *neutron_dmabuf_map(struct dma_buf_attachment *attach,
+					   enum dma_data_direction dir)
 {
-	struct neutron_buffer *buf = file->private_data;
+	struct neutron_buffer *buf = attach->dmabuf->priv;
+	struct sg_table *sgt;
+	int ret;
 
-	dev_dbg(buf->ndev->dev, "Buffer release. file=0x%pS, buf=0x%pS\n",
-		file, buf);
+	sgt = kzalloc(sizeof(*sgt), GFP_KERNEL);
+	if (!sgt)
+		return ERR_PTR(-ENOMEM);
+
+	/* Build sg_table from the CMA allocation — dma_get_sgtable_attrs
+	 * correctly describes the physical pages regardless of how the
+	 * kernel virtual address was mapped. */
+	ret = dma_get_sgtable_attrs(buf->ndev->dev, sgt, buf->cpu_addr,
+				    buf->dma_addr, buf->size,
+				    DMA_ATTR_FORCE_CONTIGUOUS);
+	if (ret) {
+		kfree(sgt);
+		return ERR_PTR(ret);
+	}
+
+	/* Create IOMMU mappings for the IMPORTING device (e.g. Mali GPU).
+	 * This is critical — without it, the importer's IOMMU has no
+	 * translation for these pages and writes go nowhere. */
+	ret = dma_map_sgtable(attach->dev, sgt, dir, DMA_ATTR_SKIP_CPU_SYNC);
+	if (ret) {
+		sg_free_table(sgt);
+		kfree(sgt);
+		return ERR_PTR(ret);
+	}
 
-	neutron_buffer_put(buf);
+	return sgt;
+}
 
-	return 0;
+static void neutron_dmabuf_unmap(struct dma_buf_attachment *attach,
+				 struct sg_table *sgt,
+				 enum dma_data_direction dir)
+{
+	dma_unmap_sgtable(attach->dev, sgt, dir, DMA_ATTR_SKIP_CPU_SYNC);
+	sg_free_table(sgt);
+	kfree(sgt);
 }
 
-static int neutron_buffer_mmap(struct file *file,
+static int neutron_dmabuf_mmap(struct dma_buf *dmabuf,
 			       struct vm_area_struct *vma)
 {
-	struct neutron_buffer *buf = file->private_data;
-	int ret;
+	struct neutron_buffer *buf = dmabuf->priv;
 
-	dev_dbg(buf->ndev->dev, "Buffer mmap. file=0x%pS, buf=0x%pS\n",
-		file, buf);
+	/* dma_buf_mmap() sets vma->vm_pgoff to the offset within the buffer.
+	 * dma_mmap_attrs() adds vm_pgoff internally, so reset to 0 here.
+	 */
+	vma->vm_pgoff = 0;
+
+	return dma_mmap_attrs(buf->ndev->dev, vma, buf->cpu_addr,
+			      buf->dma_addr, buf->size,
+			      DMA_ATTR_FORCE_CONTIGUOUS);
+}
 
-	ret = dma_mmap_attrs(buf->ndev->dev, vma, buf->cpu_addr,
-			     buf->dma_addr, buf->size, DMA_ATTR_FORCE_CONTIGUOUS);
+static void neutron_dmabuf_release(struct dma_buf *dmabuf)
+{
+	struct neutron_buffer *buf = dmabuf->priv;
 
-	return ret;
+	neutron_buffer_put(buf);
 }
 
+static int neutron_dmabuf_begin_cpu_access(struct dma_buf *dmabuf,
+					   enum dma_data_direction dir)
+{
+	struct neutron_buffer *buf = dmabuf->priv;
+
+	dma_sync_single_for_cpu(buf->ndev->dev, buf->dma_addr,
+				buf->size, dir);
+	return 0;
+}
+
+static int neutron_dmabuf_end_cpu_access(struct dma_buf *dmabuf,
+					 enum dma_data_direction dir)
+{
+	struct neutron_buffer *buf = dmabuf->priv;
+
+	dma_sync_single_for_device(buf->ndev->dev, buf->dma_addr,
+				   buf->size, dir);
+	return 0;
+}
+
+static const struct dma_buf_ops neutron_dmabuf_ops = {
+	.map_dma_buf      = neutron_dmabuf_map,
+	.unmap_dma_buf    = neutron_dmabuf_unmap,
+	.mmap             = neutron_dmabuf_mmap,
+	.release          = neutron_dmabuf_release,
+	.begin_cpu_access = neutron_dmabuf_begin_cpu_access,
+	.end_cpu_access   = neutron_dmabuf_end_cpu_access,
+};
+
+/****************************************************************************/
+
 int neutron_buffer_create(struct neutron_device *ndev,
 			  size_t size, __u64 *addr_out)
 {
 	struct neutron_buffer *buf;
+	DEFINE_DMA_BUF_EXPORT_INFO(exp_info);
 	int ret = -ENOMEM;
 
 	if (!size)
@@ -97,13 +159,23 @@
 	if (!buf->cpu_addr)
 		goto free_buf;
 
-	ret = anon_inode_getfd("neutron-buffer", &neutron_buffer_fops, buf,
-			       O_RDWR | O_CLOEXEC);
-	if (ret < 0)
+	exp_info.ops = &neutron_dmabuf_ops;
+	exp_info.size = PAGE_ALIGN(buf->size);
+	exp_info.flags = O_RDWR | O_CLOEXEC;
+	exp_info.priv = buf;
+	exp_info.exp_name = "neutron";
+
+	buf->dmabuf = dma_buf_export(&exp_info);
+	if (IS_ERR(buf->dmabuf)) {
+		ret = PTR_ERR(buf->dmabuf);
 		goto free_dma;
+	}
 
-	buf->file = fget(ret);
-	fput(buf->file);
+	ret = dma_buf_fd(buf->dmabuf, O_RDWR | O_CLOEXEC);
+	if (ret < 0)
+		goto free_dmabuf;
+
+	buf->file = buf->dmabuf->file;
 	*addr_out = buf->dma_addr;
 
 	dev_dbg(buf->ndev->dev,
@@ -112,6 +184,9 @@
 
 	return ret;
 
+free_dmabuf:
+	dma_buf_put(buf->dmabuf);
+
 free_dma:
 	dma_free_attrs(buf->ndev->dev, buf->size, buf->cpu_addr,
 		       buf->dma_addr, DMA_ATTR_FORCE_CONTIGUOUS);
@@ -125,14 +200,19 @@
 struct neutron_buffer *neutron_buffer_get_from_fd(int fd)
 {
 	struct neutron_buffer *buf;
-	struct file *file;
+	struct dma_buf *dmabuf;
+
+	dmabuf = dma_buf_get(fd);
+	if (IS_ERR(dmabuf))
+		return ERR_PTR(-EINVAL);
 
-	file = fget(fd);
-	if (!file)
+	if (dmabuf->ops != &neutron_dmabuf_ops) {
+		dma_buf_put(dmabuf);
 		return ERR_PTR(-EINVAL);
+	}
 
-	buf = file->private_data;
-	fput(file);
+	buf = dmabuf->priv;
+	dma_buf_put(dmabuf);
 
 	return buf;
 }
--- a/drivers/staging/neutron/neutron_buffer.h
+++ b/drivers/staging/neutron/neutron_buffer.h
@@ -15,11 +15,13 @@
 
 struct neutron_device;
 struct device;
+struct dma_buf;
 
 /**
  * struct neutron_buffer - Buffer
  * @dev:                Device
  * @file:               File
+ * @dmabuf:             DMA-BUF handle
  * @kref:               Reference counting
  * @capacity:           Maximum capacity of the buffer
  * @cpu_addr:           Kernel mapped address
@@ -31,6 +33,7 @@
 struct neutron_buffer {
 	struct neutron_device *ndev;
 	struct file           *file;
+	struct dma_buf        *dmabuf;
 	struct kref           kref;
 	size_t                size;
 	void                  *cpu_addr;
